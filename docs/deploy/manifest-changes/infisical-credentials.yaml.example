# Universal-auth (machine identity) credentials for the Infisical operator to read the
# playzy-prd project. Applied MANUALLY once (never committed — this is the plaintext
# bootstrap); the operator then syncs the `playzy-secret` managed Secret from Infisical.
#
#   cp infisical-credentials.yaml.example /tmp/playzy-infisical-credentials.yaml
#   # fill clientId / clientSecret from the Infisical machine identity for playzy-prd
#   kubectl apply -f /tmp/playzy-infisical-credentials.yaml
#   rm /tmp/playzy-infisical-credentials.yaml
#
# The app secrets themselves (KAGI_EMAIL, KAGI_PASSWORD, PLAYZY_ADMIN_TOKEN,
# PLAYZY_DATABASE_URL) live in the Infisical project playzy-prd (env prd, path /) — add
# them there, not here.
apiVersion: v1
kind: Secret
metadata:
  name: infisical-universal-auth
  namespace: playzy
type: Opaque
stringData:
  clientId: "REPLACE_INFISICAL_MACHINE_IDENTITY_CLIENT_ID"
  clientSecret: "REPLACE_INFISICAL_MACHINE_IDENTITY_CLIENT_SECRET"
